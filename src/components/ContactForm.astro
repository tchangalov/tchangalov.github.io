---
const {
  title = "Let's Work Together",
  description = "Have a project in mind? Need a custom quote? Fill out the form below and I'll get back to you within 24 hours."
} = Astro.props;
---

<section class="card bg-base-100 shadow-xl p-6 md:p-8 max-w-2xl mx-auto">
  <h2 class="text-2xl font-bold mb-2">{title}</h2>
  <p class="text-base-content/70 mb-6">{description}</p>
  
  <form 
    action="https://api.web3forms.com/submit" 
    method="POST" 
    class="space-y-4"
    id="contact-form"
  >
    <input type="hidden" name="access_key" value="24b5ed2a-ed14-4a87-85ac-eb79f42a7c91">
    <input type="hidden" name="subject" value="New Contact Form Submission from tchangalov.github.io">
    <input type="hidden" name="from_name" value="Website Contact Form">
    <input type="hidden" name="redirect" value="https://tchangalov.github.io/contact-success">
    
    <div class="form-control">
      <label class="label" for="name">
        <span class="label-text">Your Name</span>
      </label>
      <input 
        type="text" 
        name="name" 
        id="name"
        class="input input-bordered w-full" 
        required 
        placeholder="John Doe"
      />
    </div>
    
    <div class="form-control">
      <label class="label" for="email">
        <span class="label-text">Email Address</span>
      </label>
      <input 
        type="email" 
        name="email" 
        id="email"
        class="input input-bordered w-full" 
        required 
        placeholder="john@example.com"
      />
    </div>
    
    <div class="form-control">
      <label class="label" for="company">
        <span class="label-text">Company / Organization (optional)</span>
      </label>
      <input 
        type="text" 
        name="company" 
        id="company"
        class="input input-bordered w-full" 
        placeholder="Acme Inc."
      />
    </div>
    
    <div class="form-control">
      <label class="label" for="service">
        <span class="label-text">Service of Interest</span>
      </label>
      <select 
        name="service" 
        id="service"
        class="select select-bordered w-full"
      >
        <option value="" disabled selected>Select a service...</option>
        <option value="Tutoring">Tutoring / Premium Tutoring</option>
        <option value="Technology Training">Technology Training Services</option>
        <option value="Software Consulting">Tailored Software & Consulting</option>
        <option value="Other">Other</option>
      </select>
    </div>
    
    <div class="form-control">
      <label class="label" for="message">
        <span class="label-text">Message</span>
      </label>
      <textarea 
        name="message" 
        id="message"
        class="textarea textarea-bordered w-full min-h-[120px]" 
        required 
        placeholder="Tell me about your project, goals, timeline, and any specific requirements..."
      ></textarea>
    </div>
    
    <div class="form-control">
      <label class="label cursor-pointer justify-start gap-2">
        <input type="checkbox" name="botcheck" class="checkbox checkbox-primary hidden" />
        <span class="label-text text-sm text-base-content/60">
          I'm not a robot (this field prevents spam)
        </span>
      </label>
    </div>
    
    <button 
      type="submit" 
      class="btn btn-primary w-full md:w-auto mt-4"
      id="submit-btn"
    >
      <span class="btn-text">Send Message</span>
      <span class="btn-loading loading loading-spinner hidden"></span>
    </button>
    
    <p class="text-sm text-base-content/50 text-center">
      By submitting this form, you agree to be contacted via email regarding your inquiry.
    </p>
</form>

  <div class="divider my-6">or</div>

  <div class="text-center">
    <a 
      href="https://calendly.com/i-tchangalov/30min" 
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-outline btn-lg w-full md:w-auto"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      Book a 30-min Call on Calendly
    </a>
    <p class="text-sm text-base-content/50 mt-2">Pick a time that works for you.</p>
  </div>

  <!-- Success/Error messages -->
  <div id="form-status" class="hidden mt-4"></div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = submitBtn.querySelector('.btn-text');
    const btnLoading = submitBtn.querySelector('.btn-loading');
    const statusDiv = document.getElementById('form-status');
    
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Show loading state
      submitBtn.disabled = true;
      btnText.classList.add('hidden');
      btnLoading.classList.remove('hidden');
      statusDiv.classList.add('hidden');
      statusDiv.className = 'hidden mt-4';
      
      const formData = new FormData(form);
      
      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });
        
        const result = await response.json();
        
        if (result.success) {
          statusDiv.className = 'alert alert-success mt-4';
          statusDiv.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span>Thanks for reaching out! I'll get back to you within 24 hours.</span>
          `;
          statusDiv.classList.remove('hidden');
          form.reset();
        } else {
          throw new Error(result.message || 'Something went wrong');
        }
      } catch (error) {
        statusDiv.className = 'alert alert-error mt-4';
        statusDiv.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>Oops! Something went wrong. Please try again or email me directly at i.tchangalov@gmail.com</span>
        `;
        statusDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        btnText.classList.remove('hidden');
        btnLoading.classList.add('hidden');
      }
    });
  });
</script>