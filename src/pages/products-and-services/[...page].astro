---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalShopItem from "../../components/HorizontalShopItem.astro";
import { getCollection } from "astro:content";
import ContactForm from "../../components/ContactForm.astro";

export async function getStaticPaths({ paginate }) {
  const items = await getCollection("store");
  items.sort((a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf());
  return paginate(items, { pageSize: 10 });
}
const { page } = Astro.props;

// Separate items by buyer persona
const studentItems = page.data.filter(item => 
  item.data.title === "Tutoring" || item.data.title === "Premium Tutoring"
);

const professionalItems = page.data.filter(item => 
  item.data.title === "Technology Training Services"
);

const businessItems = page.data.filter(item => 
  item.data.title === "Tailored Software & Consulting for Growing Businesses"
);
---

<BaseLayout title="Products & Services" sideBarActiveItemID="store">
  <div class="prose max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold mb-4">Products & Services</h1>
    <p class="text-lg text-base-content/70 mb-12">
      Tailored offerings for businesses, professional teams, and individual learners. 
      Find the right fit for your goals.
    </p>
  </div>

  <!-- Businesses & Organizations -->
  <section class="mb-16" id="businesses">
    <div class="divider text-3xl font-bold mb-8">Businesses & Organizations</div>
    <div class="grid gap-6">
      {businessItems.map((item) => (
          <HorizontalShopItem
            title={item.data.title}
            img={item.data.heroImage}
            desc={item.data.description}
            pricing={item.data.pricing}
            oldPricing={item.data.oldPricing}
            checkoutUrl={item.data.checkoutUrl}
            badge={item.data.badge}
            details={item.data.details}
            tags={item.data.tags}
            url={"/products-and-services/" + item.slug}
          />
      ))}
    </div>
  </section>

  <!-- Professionals & Teams -->
  <section class="mb-16" id="professionals">
    <div class="divider text-3xl font-bold mb-8">Professional Teams</div>
    <div class="grid gap-6">
      {professionalItems.map((item) => (
          <HorizontalShopItem
            title={item.data.title}
            img={item.data.heroImage}
            desc={item.data.description}
            pricing={item.data.pricing}
            oldPricing={item.data.oldPricing}
            checkoutUrl={item.data.checkoutUrl}
            badge={item.data.badge}
            details={item.data.details}
            tags={item.data.tags}
            url={"/products-and-services/" + item.slug}
          />
      ))}
    </div>
  </section>

  <!-- Students & Individual Learners -->
  <section class="mb-16" id="students">
    <div class="divider text-3xl font-bold mb-8">Tutoring</div>
    <div class="grid gap-6 md:grid-cols-2">
      {studentItems.map((item) => (
          <HorizontalShopItem
            title={item.data.title}
            img={item.data.heroImage}
            desc={item.data.description}
            pricing={item.data.pricing}
            oldPricing={item.data.oldPricing}
            checkoutUrl={item.data.checkoutUrl}
            badge={item.data.badge}
            details={item.data.details}
            tags={item.data.tags}
            url={"/products-and-services/" + item.slug}
          />
      ))}
    </div>
  </section>

  <!-- Contact / Lead Capture -->
  <section class="mb-16" id="contact">
    <ContactForm />
    <p class="text-base-content/60 mt-6 text-center">
      Or email me directly: <a href="mailto:i.tchangalov@gmail.com" class="underline hover:text-primary">i.tchangalov@gmail.com</a>
    </p>
  </section>

  <div class="flex justify-between">
    {
      page.url.prev ? (
        <a href={page.url.prev} class="btn btn-ghost my-10 mx-5">
          {" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
          </svg>{" "}
          Previous page
        </a>
      ) : (
        <div />
      )
    }
    {
      page.url.next ? (
        <a href={page.url.next} class="btn btn-ghost my-10 mx-5">
          Next page{" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            {" "}
            <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
          </svg>
        </a>
      ) : (
        <div />
      )
    }
  </div>
</BaseLayout>